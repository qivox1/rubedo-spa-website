---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';

const title = 'Termin & Kontakt — Rubedo Spa Minden';
const description = 'Termin vereinbaren oder Kontakt aufnehmen — persönliche Beratung im Rubedo Spa Minden, Marienstraße 58. Kostenfreies 15-Min-Erstgespräch per Video, Telefon, E-Mail und Anfahrt.';
const heroImage = '/images/lina-termin-buchen.webp';
const hasBookingEmbed = !!site.booking.embedUrl;
---

<BaseLayout title={title} description={description} heroImage={heroImage}>
  <article class="rb-page" data-page="termin-buchen">

    <!-- HERO · persönliches Beratungsmotiv -->
    <section class="rb-block-hero rb-block-hero--photo">
      <div class="rb-block-hero__photo">
        <img src="/images/lina-termin-buchen.webp" alt="Junge Frau am warmen Eichentisch, ein kleines Notizbuch in beiden Händen, ruhiges nachdenkliches Lächeln — der Moment vor der Buchung" width="1344" height="768" fetchpriority="high" />
        <div class="rb-wrap">
          <div class="rb-block-hero__copy">
            <span class="rb-block-hero__eyebrow">Termin · Beratung · Kontakt</span>
            <h1>Lass uns sprechen.</h1>
            <p class="rb-block-hero__subline">Persönliche Beratung — im Studio in Minden oder per Videocall. 15 Minuten Erstgespräch mit Monica, kostenfrei. Du entscheidest danach, ob und wie du beginnen möchtest.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TERMIN & KONTAKT · Formular + direkter Kontakt/Studio -->
    <section id="termin" class="rb-section rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-tk-grid">

          <div class="rb-tk-form">
            {hasBookingEmbed ? (
              <div class="rb-booking-embed" data-reveal>
                <iframe
                  src={site.booking.embedUrl}
                  width="100%"
                  height="720"
                  frameborder="0"
                  loading="lazy"
                  title="Termin buchen"
                  style="border:0;border-radius:var(--rb-radius-md);"
                ></iframe>
              </div>
            ) : (
              <div class="rb-booking-fallback" data-reveal>
                <div class="rb-eyebrow">Termin anfragen</div>
                <h2>Schreib uns kurz — wir melden uns innerhalb eines Werktags.</h2>
                <form class="rb-booking-form" name="termin" method="POST" action="/api/termin" data-reveal>
                  <div class="rb-form-row">
                    <label>
                      <span>Name <em class="rb-required" aria-hidden="true">*</em></span>
                      <input type="text" name="name" required autocomplete="name" />
                    </label>
                    <label>
                      <span>E-Mail <em class="rb-required" aria-hidden="true">*</em></span>
                      <input type="email" name="email" required autocomplete="email" />
                    </label>
                  </div>
                  <div class="rb-form-row">
                    <label>
                      <span>Telefon</span>
                      <input type="tel" name="phone" autocomplete="tel" />
                    </label>
                    <label>
                      <span>Ich interessiere mich für …</span>
                      <select name="interest">
                        <option value="erstgespraech">Kostenfreies Erstgespräch (15 min)</option>
                        <option value="dna-skin">DNA Skin Intelligence</option>
                        <option value="kryo">Kryo Vital · Ganzkörper</option>
                        <option value="kryo-facial">Kryo Vital · Facial</option>
                        <option value="koerperformung">Körperformung · Druckwellen / Wraps</option>
                        <option value="inner-source">Inner Source · Massage / Atem</option>
                        <option value="anderes">Etwas anderes</option>
                      </select>
                    </label>
                  </div>
                  <label>
                    <span>Nachricht (optional)</span>
                    <textarea name="message" rows="4"></textarea>
                  </label>

                  {/* Cloudflare Turnstile Container — wird via Klaro-Consent geladen */}
                  <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY"></div>

                  <label class="rb-form-consent">
                    <input type="checkbox" name="dsgvo" required />
                    <span>Ich habe die <a href="/datenschutz/">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Anfrage zu.</span>
                  </label>

                  <button type="submit" class="rb-btn rb-btn--primary rb-btn--lg">Anfrage senden</button>
                </form>
              </div>
            )}
          </div>

          <aside class="rb-tk-side">
            <div class="rb-tk-contact">
              <span class="rb-eyebrow">Direkt erreichen</span>
              <h3>Persönlich, ohne Auto-Reply.</h3>
              <ul class="rb-tk-contact__list">
                <li><strong>Telefon</strong><a href={`tel:${site.contact.phoneE164}`}>{site.contact.phoneDisplay}</a></li>
                <li><strong>E-Mail</strong><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
                <li><strong>Adresse</strong><span>Marienstraße 58, 32427 Minden</span></li>
                <li><strong>Mo–Fr</strong><span>09:00 — 19:00 Uhr</span></li>
                <li><strong>Sa</strong><span>10:00 — 16:00 Uhr · nach Vereinbarung</span></li>
              </ul>
            </div>
            <a class="rb-tk-studio" href="#kontakt" aria-label="Studio &amp; Anfahrt ansehen">
              <img src="/images/location/location-eingang-rubedo-spa-minden-hero.webp" alt="Eingang des Rubedo Spa Minden — Stuckvilla mit modernem Anbau in der Marienstraße 58" width="800" height="500" loading="lazy" />
              <span class="rb-tk-studio__cap">Unser Studio · Marienstraße 58 →</span>
            </a>
          </aside>

        </div>
      </div>
    </section>

    <!-- DREI WEGE + ABLAUF + STORNO -->
    <section class="rb-section rb-section--cream rb-section--tight">
      <div class="rb-wrap rb-wrap--narrow rb-prose">
        <span class="rb-eyebrow">Was Sie erwartet</span>
        <h2>Drei Wege, mit Rubedo zu beginnen.</h2>

        <h3>1. Kostenfreies Erstgespräch (15 Minuten, Videocall)</h3>
        <p>
          Der ruhigste Einstieg. Wir besprechen, was Sie suchen — Hautpflege, Vitalität,
          Körpergefühl, Atem oder eine Kombination — und Monica erklärt, welche der drei
          Säulen für Sie der passende Anker ist. Kein Verkaufsgespräch, keine
          Auto-E-Mail im Anschluss. Sie entscheiden danach, ob Sie buchen möchten.
        </p>

        <h3>2. Konkrete Anwendung im Studio</h3>
        <p>
          Wenn Sie bereits wissen, was Sie suchen, buchen Sie direkt eine Anwendung —
          Kryo-Suite, Kryo-Facial, Druckwellen, Massage in der Rubedo Suite oder eine
          DNA-Skin-Konsultation. Vor jeder Erstanwendung füllen Sie einen kurzen
          Anamnese-Bogen aus. Alle Anwendungen mit Dauer und Preis finden Sie in der
          <a href="/leistungen-preise/">Leistungsübersicht</a>.
        </p>

        <h3>3. Geschenk-Gutschein für jemand anderen</h3>
        <p>
          Sie möchten Rubedo verschenken? Wir stellen Wertgutscheine, Anwendungs-Gutscheine
          und kuratierte Säulen-Erlebnisse persönlich aus — Details auf der
          <a href="/gutscheine/">Gutschein-Seite</a>.
        </p>

        <h3>So läuft die Erstanwendung ab</h3>
        <p>
          Sie kommen 10 Minuten vor dem Termin an, erhalten Robe und Handtuch, und beginnen
          mit einem ruhigen Aufnahmegespräch. Die eigentliche Anwendung dauert je nach
          Buchung 30 bis 90 Minuten. Anschließend besprechen wir mit Ihnen, ob und wie
          eine zweite Anwendung sinnvoll wäre — ohne Verkaufsdruck.
        </p>

        <h3>Stornierung &amp; Umbuchung</h3>
        <p>
          Termine können bis 24 Stunden vorher kostenfrei storniert oder umgebucht werden.
          Bei kurzfristigen Absagen erheben wir 50 % des Anwendungspreises, da der
          reservierte Slot anderen Gästen sonst verloren geht. Wer einen Gutschein
          einlöst, behält bei Stornierung den vollen Wert.
        </p>
      </div>
    </section>

    <!-- STANDORT & KONTAKT · Fassaden-Detail + Adresse -->
    <section id="kontakt" class="rb-block-imgtext rb-section--paper">
      <div class="rb-wrap">
        <div class="rb-imgtext rb-imgtext--reverse">
          <div class="rb-imgtext__media">
            <img src="/images/location/location-fassade-detail-rubedo-spa-minden-detail.webp" alt="Fassaden-Detail des Rubedo Spa — ionische Säule und Blumenreliefs an der Stuckfassade" width="800" height="376" loading="lazy" />
          </div>
          <div class="rb-imgtext__body">
            <span class="rb-eyebrow">Standort &amp; Kontakt</span>
            <h2>Marienstraße 58 · 32427 Minden.</h2>
            <p>Direkt im Herzen der Innenstadt — Parkmöglichkeiten in Gehweite, der Hauptbahnhof zu Fuß in 12 Minuten erreichbar. Wer mit dem Rad anreist, findet in der Marienstraße 58 sichere Abstellmöglichkeiten direkt am Studio-Eingang.</p>
            <ul class="rb-contact__list">
              <li><strong>Adresse</strong><span>Rubedo Spa, Marienstraße 58, 32427 Minden</span></li>
              <li><strong>Telefon</strong><span><a href={`tel:${site.contact.phoneE164}`}>{site.contact.phoneDisplay}</a></span></li>
              <li><strong>E-Mail</strong><span><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></span></li>
              <li><strong>Mo–Fr</strong><span>09:00 — 19:00 Uhr</span></li>
              <li><strong>Sa</strong><span>10:00 — 16:00 Uhr · nach Vereinbarung</span></li>
              <li><strong>So</strong><span>geschlossen</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ANFAHRT -->
    <section class="rb-section rb-section--cream rb-section--tight">
      <div class="rb-wrap rb-prose">
        <span class="rb-eyebrow">Anfahrt &amp; Anreise</span>
        <h2>So finden Sie zu uns.</h2>
        <p>
          Das Rubedo Spa liegt im Zentrum, eingebettet in das historische
          Marienviertel. Die Marienstraße 58 ist Teil der ruhigen Wohnlage zwischen
          Marienkirche und Stadttheater — fußläufig zum Domhof, zur Fußgängerzone
          und zur Weserpromenade.
        </p>

        <h3>Mit dem Auto</h3>
        <p>
          Über die A2, Ausfahrt Bad Eilsen, dann B65 Richtung Zentrum. Parkplätze finden Sie
          rund um die Marienstraße — kostenpflichtig im Parkhaus „Markt-Carrée" (Markt 1)
          oder kostenfrei nach 19:00 Uhr in der Königsstraße. Wir empfehlen, etwa 10 Minuten
          Puffer für die Parkplatzsuche einzuplanen.
        </p>

        <h3>Mit Bahn &amp; Bus</h3>
        <p>
          Vom Hauptbahnhof sind es zu Fuß 12 Minuten — über die Bismarckstraße,
          dann links in die Marienstraße. Mit dem Stadtbus erreichen Sie uns über die
          Linien 401 und 402, Haltestelle „Markt".
        </p>

        <h3>Mit dem Rad</h3>
        <p>
          Die Stadt ist Knotenpunkt im Weserradweg. Direkt am Studio finden Sie zwei
          überdachte Bügel — bringen Sie gern Ihr eigenes Schloss mit. E-Bike-Lader auf
          Wunsch im Eingangsbereich.
        </p>

        <h3>Barrierefreiheit</h3>
        <p>
          Das Studio ist über eine Stufe (15 cm) erreichbar. Falls Sie auf Rollstuhl- oder
          Rollator-Zugang angewiesen sind, melden Sie sich bitte vorab telefonisch — wir
          haben eine mobile Rampe und richten den Empfang im Erdgeschoss ein. Die
          Behandlungssuiten sind ebenerdig.
        </p>

        <h3>Anreise von außerhalb</h3>
        <p>
          Aus Hannover, Bielefeld, Hamburg oder Bremen ist das Studio in unter 90 Minuten
          erreichbar. Auf Wunsch reservieren wir eine ruhige Übernachtung im
          Partnerhotel — mit fünf Minuten Fußweg zum Studio. Sprechen Sie uns gern im
          Erstgespräch darauf an.
        </p>
      </div>
    </section>

    <section class="rb-block-cta">
      <div class="rb-wrap">
        <div class="rb-cta-band">
          <div class="rb-cta-band__body">
            <span class="rb-eyebrow">Persönlich beraten</span>
            <h3>Noch unsicher? Ein kurzes Gespräch klärt das Meiste.</h3>
            <p>Wir melden uns innerhalb von 24 Stunden zurück — siezend, persönlich, ohne automatisierte Antwort.</p>
          </div>
          <div class="rb-cta-band__action"><a class="rb-btn--ghost-light" href="#termin">Zum Formular →</a></div>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>

<style>
  /* Zwei-Spalten-Layout: Formular + direkter Kontakt / Studio-Bild */
  .rb-tk-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 44px;
    align-items: start;
  }
  @media (max-width: 860px) {
    .rb-tk-grid { grid-template-columns: 1fr; gap: 36px; }
  }

  .rb-tk-contact {
    padding: 26px 28px;
    background: var(--rb-gold-50, #f7f1e6);
    border: 1px solid var(--rb-ink-100);
    border-radius: var(--rb-radius-md, 14px);
  }
  .rb-tk-contact h3 { margin: 6px 0 16px; font-family: var(--rb-font-display); font-weight: 400; font-size: 22px; }
  .rb-tk-contact__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .rb-tk-contact__list li { display: flex; justify-content: space-between; gap: 16px; font-family: var(--rb-font-body); font-size: 14px; border-bottom: 1px dashed var(--rb-ink-100); padding-bottom: 10px; }
  .rb-tk-contact__list li:last-child { border-bottom: 0; padding-bottom: 0; }
  .rb-tk-contact__list strong { color: var(--rb-ink-500); font-weight: 500; letter-spacing: 0.03em; }
  .rb-tk-contact__list a { color: var(--rb-gold-700); text-decoration: none; }
  .rb-tk-contact__list a:hover { text-decoration: underline; }

  .rb-tk-studio {
    position: relative; display: block;
    margin-top: 20px;
    border-radius: var(--rb-radius-md, 14px);
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(28,23,18,0.10);
    text-decoration: none;
  }
  .rb-tk-studio img { width: 100%; height: auto; display: block; transition: transform 600ms cubic-bezier(.2,.65,.3,1); }
  .rb-tk-studio:hover img { transform: scale(1.04); }
  .rb-tk-studio__cap {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 16px 18px;
    font-family: var(--rb-font-body); font-size: 13px; letter-spacing: 0.03em;
    color: #fff;
    background: linear-gradient(to top, rgba(28,23,18,0.72), rgba(28,23,18,0));
  }

  /* Formular-Styles (übernommen) */
  .rb-booking-form { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
  .rb-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 640px) { .rb-form-row { grid-template-columns: 1fr; } }
  .rb-booking-form label { display: flex; flex-direction: column; gap: 6px; font-family: var(--rb-font-body); font-size: 14px; }
  .rb-booking-form span { color: var(--rb-ink-700); letter-spacing: 0.04em; }
  .rb-booking-form input,
  .rb-booking-form select,
  .rb-booking-form textarea {
    padding: 12px 14px;
    border: 1px solid var(--rb-ink-300);
    border-radius: var(--rb-radius-md);
    font-family: inherit; font-size: 16px;
    background: var(--rb-paper); color: var(--rb-ink-900);
    transition: border-color var(--rb-dur-1) var(--rb-ease);
  }
  .rb-booking-form input:focus,
  .rb-booking-form select:focus,
  .rb-booking-form textarea:focus {
    outline: 2px solid var(--rb-gold-500);
    outline-offset: 2px;
    border-color: var(--rb-gold-500);
  }
  .rb-form-consent { flex-direction: row !important; gap: 10px !important; align-items: flex-start; }
  .rb-form-consent input { width: 18px; height: 18px; margin-top: 2px; }
  .rb-form-consent span { font-size: 13px; color: var(--rb-ink-500); }
  .rb-form-consent a { color: var(--rb-gold-700); text-decoration: underline; }
</style>
