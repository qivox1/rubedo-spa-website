---
/**
 * Stub für /magazin/example-artikel/ — alte WordPress-URL.
 * Cloudflare _redirects sollte diese URL bereits abfangen und
 * 301 → /magazin/wellness-minden-technologie/ liefern. Diese Datei
 * dient nur als Sicherheitsnetz, falls _redirects ausfällt.
 *
 * Eindeutiger Title + canonical auf Zielartikel + noindex/nofollow
 * verhindert, dass die Audit/Suchmaschine diese Seite als Duplikat
 * der Content-Collection-Seite indexiert.
 */
const target = '/magazin/wellness-minden-technologie/';
const canonical = 'https://rubedo-spa-website.pages.dev' + target;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <title>Weiterleitung — Rubedo Spa</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content="Diese Adresse wurde verschoben. Sie werden automatisch zum aktuellen Beitrag im Rubedo-Spa-Magazin weitergeleitet." />
  </head>
  <body>
    <p>Weiterleitung zu <a href={target}>{target}</a> …</p>
  </body>
</html>
